{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Unfoldly",
  "version": "1.0.0",
  "identifier": "Unfoldly",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run build",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Unfoldly",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "font-src": "'self' data:",
        "connect-src": "ipc: http://ipc.localhost https://huggingface.co https://api.github.com",
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-src": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGMDRBQjhDQkY1OTQxRjYKUldUMlFWbS9qS3NFejEySE9NM01ZUklYODM0dlk1c3FqVmsyc3BicEsvSlhhTmtMV3NoaGNVby8K",
      "endpoints": [
        "https://github.com/Unary-Works/Unfoldly/releases/latest/download/latest.json"
      ]
    }
  }
}
